# ── ENTORNO ──────────────────────────────────────────────────
APP_ENV=development
# Opciones: development | staging | production

# ── MYSQL ────────────────────────────────────────────────────
# root es solo para administración y el script de init; los servicios
# se conectan con el usuario de app de abajo (least-privilege).
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=change_me_in_production
MYSQL_USER=rentalai
MYSQL_PASSWORD=change_me_in_production
# Base de datos única de la app (.NET modular monolith, vía EF Core + Pomelo)
MYSQL_DATABASE=rentalai

# ── LARAVEL DB (notification worker) ─────────────────────────
# El worker de Laravel usa su propia base con el mismo usuario de app.
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=rentalai_notifications
DB_USERNAME=rentalai
DB_PASSWORD=change_me_in_production

# ── REDIS ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
# Base de datos por uso (0-15)
REDIS_DB_CACHE=0
REDIS_DB_SESSIONS=1
REDIS_DB_LOCKS=2
REDIS_DB_CHATBOT=3

# ── RABBITMQ ─────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=rentalai
RABBITMQ_PASSWORD=change_me_in_production
RABBITMQ_VHOST=/rentalai

# ── MINIO (Almacenamiento de archivos) ───────────────────────
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=rentalai_admin
MINIO_ROOT_PASSWORD=change_me_in_production
MINIO_BUCKET_PROPERTIES=property-photos
MINIO_BUCKET_KYC=kyc-documents
# URL pública para acceso desde el exterior (en local: http://localhost:9000)
MINIO_PUBLIC_URL=http://localhost:9000

# ── SEQ (Logging estructurado) ───────────────────────────────
SEQ_URL=http://seq:5341
SEQ_API_KEY=
# Dejar vacío en local, requerido en producción

# ── JWT (Auth Service) ───────────────────────────────────────
JWT_SECRET=CAMBIA_ESTO_POR_UNA_CADENA_ALEATORIA_DE_64_CHARS_MINIMO
JWT_ISSUER=https://api.rentalai.local
JWT_AUDIENCE=https://rentalai.local
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7

# ── OPENAI (KYC + Chatbot) ───────────────────────────────────
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
OPENAI_MODEL_VISION=gpt-4o
OPENAI_MODEL_CHAT=gpt-4o-mini
OPENAI_MODEL_EMBEDDINGS=text-embedding-3-small
# Límite de tokens por respuesta del chatbot
OPENAI_MAX_TOKENS=1024

# ── QDRANT (Vector DB para RAG del chatbot) ──────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=change_me_qdrant_api_key
QDRANT_COLLECTION_PROPERTIES=properties

# ── KYC (Cifrado de documentos) ──────────────────────────────
# Generar con: openssl rand -base64 32
KYC_ENCRYPTION_KEY=CAMBIA_ESTO_POR_CLAVE_AES256_BASE64
# Horas después de validación para borrar el documento
KYC_DOCUMENT_TTL_HOURS=24

# ── AZURE DOCUMENT INTELLIGENCE (KYC) ────────────────────────
AZURE_DOCUMENT_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_KEY=your_azure_document_intelligence_key

# ── HANGFIRE (Background jobs) ───────────────────────────────
HANGFIRE_DASHBOARD_USER=admin
HANGFIRE_DASHBOARD_PASSWORD=change_me_in_production

# ── SMTP (Notificaciones — usado por Laravel) ────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
# En producción: smtp.sendgrid.net o similar
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@rentalai.local
MAIL_FROM_NAME=RentalAI

# ── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://rentalai.local

# ── URLS INTERNAS DE SERVICIOS ───────────────────────────────
# El API Gateway enruta internamente — no exponer estos puertos al exterior
SERVICE_AUTH_URL=http://auth-service:8080
SERVICE_PROPERTIES_URL=http://properties-service:8080
SERVICE_BOOKING_URL=http://booking-service:8080
SERVICE_KYC_URL=http://kyc-service:8080
SERVICE_USERS_URL=http://users-service:8080
SERVICE_DASHBOARD_URL=http://dashboard-service:8080
SERVICE_CHATBOT_URL=http://chatbot-service:8080
SERVICE_FILES_URL=http://files-service:8080

# ── PUERTOS EXPUESTOS (solo para desarrollo local) ───────────
PORT_GATEWAY=5000
PORT_SWAGGER=5000
PORT_PGADMIN=5050
PORT_MINIO_CONSOLE=9001
PORT_RABBITMQ_MANAGEMENT=15672
PORT_SEQ=5341
PORT_QDRANT=6333
